{
  "ConnectionStrings": {
    "yahatl": "Host=your-postgres-host;Database=yahatl;Username=your-username;Password=your-password"
  },
  "Jwt": {
    "Key": "YourSecretKeyHere_MinimumOf32CharactersRequired!",
    "Issuer": "yahatl-api",
    "Audience": "yahatl-client"
  },
  "Mqtt": {
    "Host": "your-mqtt-broker-host",
    "Port": 1883,
    "Username": "",
    "Password": "",
    "ClientId": "yahatl-api"
  },
  "BackgroundServices": {
    "DueDateIntervalSeconds": 60,
    "BlockerIntervalSeconds": 60,
    "NotificationIntervalSeconds": 300
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
